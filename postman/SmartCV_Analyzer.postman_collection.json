          ],
          "path": [
            "api",
            "v1",
            "analyze"
          ]
        },
        "description": "Negative case with no cv_file field. The implemented API returns custom MISSING_FILE."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "const json = pm.response.json();",

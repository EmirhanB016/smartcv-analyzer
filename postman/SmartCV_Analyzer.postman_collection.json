              "pm.test(\"Error response has detail code and message\", function () {",
              "  pm.expect(json).to.have.property(\"detail\");",
              "  pm.expect(json.detail).to.have.property(\"code\", \"MISSING_FILE\");",
              "  pm.expect(json.detail).to.have.property(\"message\");",
              "});"
            ]
